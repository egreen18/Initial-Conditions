%% Content
% This investigation explores which COMBINATION of MIXED Initial Conditions 
% provides the most information for a simple Birth-Death system when the
% IC are mixed with defined starting probabilities.
% Key parameters of the system include:
%
% k_birth   =   1
% k_death   =   0.1
% tSpan     =  [0,40]
%
% This system equilbriates to a population of 10 with a half life of 6.93s
%% Preliminaries:
clear 
close all
clc
addpath(genpath('../Rotation/SSIT'));

%% Section 1: Condsidering the Extrema (0,20)
% OBSERVATION: The hierarchy of experiments by the information they provide
% Multi  IC (0,20) = 3.55e7
% Mixed  IC (0,20) = 2.20e7
% Single IC (0)    = 1.90e7
% Single IC (20)   = 1.11e7

% QUESTION: In the mixed case, a 50/50 distribution provides the most
% info... is the information gain a linear function of the two component
% ICs?

IC = [0,20];
prob = [0.5,  0.5;
        0.25, 0.75;
        0.75, 0.25];

% Iterate through each unique pair
for i = 1:size(prob,1)
    results = dOpt_birth_death_mixed(IC, prob(i,:));
    bubblePlot_mixed(results);
end
%% Section 2: Examining probability distribution 
% Test the hypothesis that the information from the mixed IC case is a
% linear combination of the two component ICs of the form:
%
% mix = (IC_1 - IC_2)*x + IC_2
%
% When we plot the data, a slope of (IC_1 - IC_2) would confirm this
% hypothesis

% OBSERVATION: Interesting! This is NOT a linear combination of its
% component ICs. The resulting curve made me thinking of a VLE diagram, and
% demonstrated that there is a non-trivial maximum probability
% distribution. This implies that if you have control over the distribution
% of ICs in the system, then you should perform this sort of analysis in
% order to optimize information gained from experimentation. Also worth
% noting: the mixed case is capable of providing more information than
% either of the two IC's alone... although it does provide less information
% that the pure Multi case. 

% D-Opt score for IC = 0
IC_0 = 1.90e7;

% D-Opt score for IC = 20
IC_20 = 1.11e7;

% Defining Probability Vectors
prob_1 = 0:5:100;
prob_2 = 100 - prob_1;
prob_1 = prob_1/100;
prob_2 = prob_2/100;

prob = [prob_1',prob_2'];

% Plot expected behavior
expected_behavior = @(x) IC_20 + x*(IC_0 - IC_20);
plot(prob_1, expected_behavior(prob_1), 'DisplayName', ...
    'Linear Combination Hypothesis', 'LineWidth',2)
hold on

% Compute model behavior
IC = [0,20];
info = ones(1,size(prob,1));

for i = 1:size(prob,1)
    results = dOpt_birth_death_mixed(IC, prob(i,:));
    info(i) = results.dOpt;
end

% Plot modeled behavior to compare to hypothesis
plot(prob_1, info, 'DisplayName', 'Model Behavior', 'LineWidth', 2)

% Beautifying
xlabel("Probability of IC = "+IC(1))
ylabel("Information by D-Optimality Criterion")
grid on
title("Is the Mixed IC Case a Linear Combination of It's Components?")
legend
%% Section 3: Repeating the Above with [0,100]
% The above results were interesting; lets see if switching out 20 for 100
% will change the shape of the Info vs Prob curve we observed in Section 2
% D-Opt score for IC = 0
IC_0 = 1.90e7;

% D-Opt score for IC = 100
IC_100 = 2.35e8;

% Defining Probability Vectors
prob_1 = 0:5:100;
prob_2 = 100 - prob_1;
prob_1 = prob_1/100;
prob_2 = prob_2/100;

prob = [prob_1',prob_2'];

% Plot expected behavior
expected_behavior = @(x) IC_100 + x*(IC_0 - IC_100);
plot(prob_1, expected_behavior(prob_1), 'DisplayName', ...
    'Linear Combination Hypothesis', 'LineWidth',2)
hold on

% Compute model behavior
IC = [0,100];
info = ones(1,size(prob,1));

for i = 1:size(prob,1)
    results = dOpt_birth_death_mixed(IC, prob(i,:));
    info(i) = results.dOpt;
end

% Plot modeled behavior to compare to hypothesis
plot(prob_1, info, 'DisplayName', 'Model Behavior', 'LineWidth', 2)

% Beautifying
xlabel("Probability of IC = "+IC(1))
ylabel("Information by D-Optimality Criterion")
grid on
title("Is the Mixed IC Case a Linear Combination of It's Components?")
legend

%% Section 4: Repeating the Above with [1,2]
% What about two adjacent IC's that should have comparable information?
% D-Opt score for IC = 0
IC_1 = 1.47e7;

% D-Opt score for IC = 100
IC_2 = 1.12e7;

% Defining Probability Vectors
prob_1 = 0:5:100;
prob_2 = 100 - prob_1;
prob_1 = prob_1/100;
prob_2 = prob_2/100;

prob = [prob_1',prob_2'];

% Plot expected behavior
